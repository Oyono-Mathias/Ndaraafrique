{
  "entities": {
    "CourseQuestion": {
      "title": "Course Question",
      "type": "object",
      "description": "A question asked by a student to a course instructor.",
      "properties": {
        "courseId": { "type": "string" },
        "courseTitle": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentAvatarUrl": { "type": "string", "format": "uri" },
        "instructorId": { "type": "string" },
        "questionText": { "type": "string" },
        "answerText": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "answered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "answeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "studentId", "instructorId", "questionText", "status", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "description": "An announcement made by an instructor for a specific course.",
      "properties": {
        "courseId": { "type": "string" },
        "instructorId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "instructorId", "title", "message", "createdAt"]
    },
    "AdminGrant": {
      "title": "Admin Course Grant",
      "type": "object",
      "description": "Records when an admin grants free access to a course for a user.",
      "properties": {
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "grantedBy": { "type": "string", "description": "UID of the admin who granted access." },
        "reason": { "type": "string", "description": "Reason for granting access." },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time", "description": "When the granted access expires." }
      },
      "required": ["studentId", "courseId", "grantedBy", "createdAt"]
    },
    "AdminAuditLog": {
      "title": "Admin Audit Log",
      "type": "object",
      "description": "Records an action performed by an administrator for auditing purposes.",
      "properties": {
        "adminId": { "type": "string" },
        "eventType": { "type": "string" },
        "target": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["adminId", "eventType", "target", "timestamp", "details"]
    },
    "Role": {
      "title": "Role",
      "type": "object",
      "description": "Defines a set of permissions for a user role.",
      "properties": {
        "name": { "type": "string" },
        "permissions": { "type": "object" }
      },
      "required": ["name", "permissions"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user in the Ndara Afrique application.",
      "properties": {
        "uid": { "type": "string", "format": "uuid" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "default": "student" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "isInstructorApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username", "createdAt", "role", "status"]
    },
    "Course": {
      "title": "Course",
      "type": "object",
      "description": "Represents a course offered on the Ndara Afrique platform.",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructorId": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Published", "Pending Review"] },
        "rating": { "type": "number" },
        "participantsCount": { "type": "number" }
      },
      "required": ["courseId", "title", "description", "instructorId", "category", "price", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "questions/{questionId}": {
      "schema": { "$ref": "#/entities/CourseQuestion" },
      "description": "Questions asked by students to instructors."
    },
    "courses/{courseId}/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Announcements for a specific course."
    },
    "admin_audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AdminAuditLog" },
      "description": "Log of actions performed by administrators."
    },
    "roles/{roleId}": {
        "schema": { "$ref": "#/entities/Role" }
    },
    "users/{userId}": {
        "schema": { "$ref": "#/entities/User" }
    },
    "courses/{courseId}": {
        "schema": { "$ref": "#/entities/Course" }
    }
  }
}

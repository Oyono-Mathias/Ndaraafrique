rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLES DE DÉVELOPPEMENT (DÉVERROUILLAGE) ---
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // --- PROFIL UTILISATEUR ---
    match /users/{userId} {
      allow read: if true; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /notifications/{notifId} {
        allow create, read, update: if isOwner(userId);
      }
      
      match /chatHistory/{msgId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- ENROLLMENTS (INSCRIPTIONS) ---
    match /enrollments/{enrollmentId} {
      // ✅ FIX PERMISSION : On autorise la lecture si l'ID commence par l'UID de l'utilisateur.
      // Cela permet le 'get' et le 'onSnapshot' même si le document n'existe pas encore.
      allow read: if isSignedIn() && (
        enrollmentId.startsWith(request.auth.uid) || 
        isAdmin() ||
        (resource != null && (resource.data.studentId == request.auth.uid || resource.data.instructorId == request.auth.uid))
      );
      allow write: if isAdmin();
    }

    // --- AVIS (REVIEWS) ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // --- QUESTIONS & RÉPONSES ---
    match /questions/{questionId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.instructorId);
      allow update: if isSignedIn() && request.auth.uid == resource.data.instructorId;
    }

    // --- ACCÈS PUBLICS ---
    match /settings/{docId} {
      allow read: if true;
    }
    
    match /faqs/{faqId} {
      allow read: if true;
    }

    match /carousel_slides/{slideId} {
      allow read: if true;
    }

    match /courses/{courseId} {
      allow read: if true; 
      
      match /{allSubcollections=**} {
        allow read: if true; 
      }
    }
  }
}
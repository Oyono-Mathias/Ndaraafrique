rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLE PAR DÉFAUT : FERMÉ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- UTILISATEURS ---
    match /users/{userId} {
      // Un utilisateur voit ses données, l'admin voit tout.
      allow read: if isOwner(userId) || isAdmin();
      
      // Création lors du signup (uniquement par le propriétaire).
      allow create: if isOwner(userId);
      
      // Mise à jour : le propriétaire ne peut pas modifier son rôle ou son statut.
      // L'admin peut tout modifier (suspension, rôle, etc.).
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status
      );
      
      // Sous-collections privées (notifications, historique de chat, etc.)
      match /notifications/{id} { allow read, write: if isOwner(userId); }
      match /chatHistory/{id} { allow read, write: if isOwner(userId); }
      match /fcmTokens/{id} { allow read, write: if isOwner(userId); }
    }

    // --- FINANCES & TRANSACTIONS (CRITIQUE) ---
    match /payments/{paymentId} {
      // Lecture par le bénéficiaire ou l'admin pour historique.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Écriture STRICTEMENT interdite au client (géré par Admin SDK côté serveur).
      allow write: if false;
    }

    match /transactions/{txnId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    match /payout_requests/{payoutId} {
      allow read: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
      // L'instructeur crée sa demande, l'admin la valide (update).
      allow create: if isSignedIn() && isOwner(request.resource.data.instructorId);
      allow update: if isAdmin();
    }

    // --- SUPPORT & MESSAGERIE ---
    match /support_tickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin(); // Seul l'admin répond ou clôture officiellement.
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn();
      }
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
      }
    }

    // --- RÉGLAGES SYSTÈME (PUBLICS) ---
    match /settings/{settingId} {
      allow read: if true; // Lecture publique pour le nom du site, logos, etc.
      allow write: if isAdmin();
    }

    // --- LOGS & AUDIT (VERROUILLÉS) ---
    match /admin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Écriture exclusive via Server Actions.
    }

    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- COURS & CONTENU ---
    match /courses/{courseId} {
      allow read: if true; // Catalogue public.
      allow write: if isAdmin() || (
        isSignedIn() && 
        resource.data.instructorId == request.auth.uid && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restrictions.canSellCourse == true
      );
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
    }

    match /enrollments/{enrollmentId} {
      allow read: if isOwner(resource.data.studentId) || isOwner(resource.data.instructorId) || isAdmin();
      allow write: if false; // Les inscriptions sont traitées par le processeur financier serveur.
    }
  }
}
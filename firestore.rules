rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLE PAR DÉFAUT : TOUT EST FERMÉ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- UTILISATEURS & PROFILS ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || true; // Lecture publique limitée pour certains compteurs
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.balance == resource.data.balance
      );
      
      match /notifications/{id} { allow read, write: if isOwner(userId); }
      match /chatHistory/{id} { allow read, write: if isOwner(userId); }
      match /fcmTokens/{id} { allow read, write: if isOwner(userId); }
      match /activity/{id} { allow read: if isOwner(userId) || isAdmin(); }
    }

    // --- FAVORIS (WISHLIST) ---
    match /user_wishlist/{wishId} {
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }

    // --- FINANCES & TRANSACTIONS ---
    match /payments/{id} {
      // Un étudiant peut lire ses propres reçus. L'admin voit tout.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Écriture réservée au serveur (Admin SDK)
    }
    
    match /payout_requests/{id} {
      allow read: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /affiliate_transactions/{id} {
      allow read: if isSignedIn() && (resource.data.affiliateId == request.auth.uid || isAdmin());
    }

    // --- COURS & PÉDAGOGIE ---
    match /courses/{courseId} {
      allow read: if true; 
      allow write: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /enrollments/{id} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
    }

    match /course_progress/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }
  }
}
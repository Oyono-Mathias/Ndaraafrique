rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COURS ---
    match /courses/{courseId} {
      allow read: if true; // Public pour le catalogue
      allow create: if isSignedIn(); 
      
      // ✅ SEUL LE CRÉATEUR ORIGINAL OU L'ADMIN PEUT SUPPRIMER/MODIFIER LE HEADER
      allow update, delete: if isAdmin() || (isSignedIn() && (resource.data.creatorId == request.auth.uid || resource.data.instructorId == request.auth.uid));
      
      // ✅ SÉCURISATION DU CONTENU PÉDAGOGIQUE
      match /sections/{sectionId} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid);
        
        match /lectures/{lectureId} {
          allow read: if true;
          allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid);
        }
        match /quizzes/{quizId} {
          allow read: if true;
          allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid);
        }
        match /assignments/{assignId} {
          allow read: if true;
          allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid);
        }
      }

      match /license_history/{historyId} {
        allow read: if isAdmin() || (isSignedIn() && (get(/databases/$(database)/documents/courses/$(courseId)).data.ownerId == request.auth.uid || get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid));
        allow write: if false; // Uniquement via Server Action (Admin SDK)
      }
    }

    // --- UTILISATEURS ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // --- AUTRES COLLECTIONS (DÉFAUT) ---
    match /{document=**} {
      allow read, write: if isAdmin() || isSignedIn();
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLE PAR DÉFAUT : TOUT EST FERMÉ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- UTILISATEURS (IDENTITÉ & PRIVILÈGES) ---
    match /users/{userId} {
      // Un utilisateur lit son profil. Les admins auditent tout.
      allow read: if isOwner(userId) || isAdmin();
      // Création autorisée à l'inscription.
      allow create: if isOwner(userId);
      // SÉCURITÉ CRITIQUE : L'utilisateur ne peut PAS changer son propre rôle.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      
      match /notifications/{id} { allow read, write: if isOwner(userId); }
      match /chatHistory/{id} { allow read, write: if isOwner(userId); }
      match /activity/{id} { allow read: if isOwner(userId) || isAdmin(); }
      match /cart/{id} { allow read, write: if isOwner(userId); }
    }

    // --- FINANCES : TRANSACTIONS & AUDIT ---
    match /payments/{paymentId} {
      // Un utilisateur ne voit que ses reçus. L'admin voit tout le flux.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // AUCUNE écriture financière autorisée depuis le client (Backend Only).
      allow write: if false;
    }

    match /transactions/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /earnings/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // --- AMBASSADEURS : AFFILIATION ---
    match /affiliate_transactions/{id} {
      // L'ambassadeur suit ses commissions. L'admin arbitre.
      allow read: if isSignedIn() && (resource.data.affiliateId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // --- TRÉSORERIE : RETRAITS ---
    match /payout_requests/{id} {
      // L'instructeur suit sa demande. L'admin valide.
      allow read: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
      // Seul l'admin peut modifier le statut (Paid/Rejected).
      allow update, delete: if isAdmin();
    }

    // --- PÉDAGOGIE : ACCÈS & CONTENU ---
    match /enrollments/{enrollmentId} {
      // Lecture si l'étudiant possède le cours ou si admin.
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      // Seul le Backend (via Admin SDK) peut valider une inscription.
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true; // Catalogue public.
      allow write: if isAdmin(); // Seul l'admin ou le backend publie.
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /course_progress/{id} {
      // L'ID est formaté {userId}_{courseId}.
      allow read: if isOwner(id.split('_')[0]) || isAdmin();
      allow write: if isOwner(id.split('_')[0]);
    }

    // --- INFRASTRUCTURE & RÉGLAGES ---
    match /settings/{id} {
      allow read: if true; // Les réglages d'UI sont publics.
      allow write: if isAdmin();
    }

    match /admin_audit_logs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /push_campaigns/{id} {
      allow read, write: if isAdmin();
    }
    
    match /marketing_campaigns/{id} {
      allow read, write: if isAdmin();
    }

    // --- SUPPORT & MESSAGERIE ---
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }
  }
}
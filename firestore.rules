rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLE PAR DÉFAUT : TOUT EST FERMÉ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- UTILISATEURS & PROFILS ---
    match /users/{userId} {
      allow read: if isSignedIn(); 
      allow create: if isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
      
      match /notifications/{id} { allow read, write: if isOwner(userId); }
      match /chatHistory/{id} { allow read, write: if isOwner(userId); }
      match /fcmTokens/{id} { allow read, write: if isOwner(userId); }
      match /activity/{id} { allow read: if isOwner(userId) || isAdmin(); }
      match /cart/{id} { allow read, write: if isOwner(userId); }
    }

    // --- FAVORIS (WISHLIST) ---
    match /user_wishlist/{wishId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- FINANCES & TRANSACTIONS ---
    match /payments/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Uniquement via Server Actions sécurisées
    }
    
    match /payout_requests/{id} {
      allow read: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /affiliate_transactions/{id} {
      allow read: if isSignedIn() && (resource.data.affiliateId == request.auth.uid || isAdmin());
    }

    // --- RÉGLAGES GÉOGRAPHIQUES & PAIEMENTS ---
    match /countries/{countryId} {
      allow read: if true; // Lecture publique pour le catalogue et le wallet
      allow write: if isAdmin();
    }

    // --- COURS & PÉDAGOGIE ---
    match /courses/{courseId} {
      allow read: if true; 
      allow write: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /enrollments/{id} {
      // ✅ FIX : Autorise le 'get' même si le document n'existe pas encore (resource == null)
      // pour permettre au tunnel de paiement de vérifier l'absence d'inscription.
      allow read: if isSignedIn() && (
        resource == null || 
        resource.data.studentId == request.auth.uid || 
        resource.data.instructorId == request.auth.uid || 
        isAdmin()
      );
      allow write: if isAdmin();
    }

    match /course_progress/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /quiz_submissions/{id} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    match /recommended_courses/{userId} {
      allow read: if isOwner(userId) || isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }
    
    match /admin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
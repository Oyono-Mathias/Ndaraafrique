rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCreator(courseId) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid;
    }

    function isCourseOwner(courseId) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/courses/$(courseId)).data.ownerId == request.auth.uid;
    }

    // --- RÉGLAGES DE LA PLATEFORME ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- ÉLÉMENTS DE DESIGN & CONTENU PUBLIC ---
    match /carousel_slides/{slideId} { allow read, list: if true; allow write: if isAdmin(); }
    match /faqs/{faqId} { allow read, list: if true; allow write: if isAdmin(); }
    match /course_templates/{templateId} { allow read, list: if true; allow write: if isAdmin(); }

    // --- COURS & CONTENU (VITRINE PUBLIQUE) ---
    match /courses/{courseId} {
      allow read, list: if true; 
      
      allow create: if isSignedIn(); 
      
      allow update: if isAdmin() || 
        isCreator(courseId) || 
        (isCourseOwner(courseId) && request.resource.data.diff(resource.data).changedKeys().hasOnly(['resaleRightsPrice', 'resaleRightsAvailable', 'updatedAt', 'buyoutStatus', 'buyoutPrice']));
      
      allow delete: if isAdmin() || isCreator(courseId);
      
      match /{allSubcollections=**} {
        allow read, list: if true;
        allow write: if isAdmin() || isCreator(courseId);
      }
    }

    // --- UTILISATEURS (PROFILS PUBLICS POUR LA CRÉDIBILITÉ) ---
    match /users/{userId} {
      allow read, list: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /notifications/{notifId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /chatHistory/{msgId} { allow read, write: if isOwner(userId); }
      match /activity/{actId} { allow read: if true; allow write: if isOwner(userId) || isAdmin(); }
      match /cart/{itemId} { allow read, write: if isOwner(userId); }
    }

    // --- AVIS & TÉMOIGNAGES (MUR DE LA SAGESSE) ---
    match /course_reviews/{reviewId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.studentId;
    }

    // --- MESSAGERIE (CHATS) ---
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // --- INSCRIPTIONS & PROGRESSION ---
    match /enrollments/{enrollId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.studentId || isAdmin() || request.auth.uid == resource.data.instructorId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.studentId);
    }
    
    match /course_progress/{progressId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn();
    }

    // --- SUPPORT & SÉCURITÉ ---
    match /support_tickets/{ticketId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      match /messages/{msgId} { allow read, write: if isSignedIn(); }
    }

    match /payments/{paymentId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin() || request.auth.uid == resource.data.instructorId);
      allow write: if isAdmin();
    }

    match /user_wishlist/{wishId} {
      allow read, write, list: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /security_logs/{logId} { allow read, write, list: if isAdmin(); }
    match /admin_audit_logs/{logId} { allow read, write, list: if isAdmin(); }
    match /investor_leads/{leadId} { allow create: if true; allow read, update, list: if isAdmin(); }

    // --- RÈGLE PAR DÉFAUT : BLOQUER LE RESTE ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
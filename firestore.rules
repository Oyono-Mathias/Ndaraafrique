rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCourseOwner(courseId) {
      const course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      return isSignedIn() && (course.ownerId == request.auth.uid || course.instructorId == request.auth.uid);
    }

    // --- RÈGLES PAR DÉFAUT : FERMÉ ---
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- RÉGLAGES PUBLICS ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carousel_slides/{slideId} { allow read: if true; }
    match /faqs/{faqId} { allow read: if true; }

    // --- COURS ---
    match /courses/{courseId} {
      allow read: if true;
      allow update: if isAdmin() || isCourseOwner(courseId);
      
      match /sections/{sectionId} {
        allow read: if true;
        match /lectures/{lectureId} { allow read: if true; }
        match /quizzes/{quizId} { allow read: if true; }
      }
    }

    // --- UTILISATEURS ---
    match /users/{userId} {
      allow read: if isSignedIn(); // Permet l'annuaire
      allow update: if isOwner(userId) || isAdmin();
      
      match /notifications/{notifId} { allow read, write: if isOwner(userId); }
      match /chatHistory/{msgId} { allow read, write: if isOwner(userId); }
      match /activity/{actId} { allow read: if isOwner(userId) || isAdmin(); }
    }

    // --- PAIEMENTS & RETRAITS ---
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /payout_requests/{payoutId} {
      allow read: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    // --- MESSAGERIE ---
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
    }

    // --- LOGS DE SÉCURITÉ ---
    match /security_logs/{logId} { allow read: if isAdmin(); allow create: if true; }
    match /admin_audit_logs/{logId} { allow read: if isAdmin(); }
  }
}
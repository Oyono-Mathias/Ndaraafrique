rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLE PAR DÉFAUT : FERMÉ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- UTILISATEURS & PROFILS ---
    match /users/{userId} {
      // Un utilisateur voit ses données, l'admin voit tout.
      allow read: if isOwner(userId) || isAdmin();
      
      // Création lors du signup (uniquement par le propriétaire).
      allow create: if isOwner(userId);
      
      // Mise à jour : le propriétaire ne peut pas modifier son rôle ou son statut.
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status
      );
      
      // Sous-collections privées
      match /notifications/{id} { allow read, write: if isOwner(userId); }
      match /chatHistory/{id} { allow read, write: if isOwner(userId); }
      match /fcmTokens/{id} { allow read, write: if isOwner(userId); }
      match /subscriptions/{id} { allow read: if isOwner(userId) || isAdmin(); }
      match /activity/{id} { allow read: if isOwner(userId) || isAdmin(); }
      match /cart/{id} { allow read, write: if isOwner(userId); }
    }

    // --- FINANCES & TRANSACTIONS (CRITIQUE - SERVER ONLY) ---
    match /payments/{id} {
      // Lecture par le bénéficiaire ou l'admin pour historique.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Écriture STRICTEMENT interdite au client (géré par Admin SDK côté serveur).
      allow write: if false; 
    }
    
    match /transactions/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /payout_requests/{id} {
      allow read: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
      // L'instructeur crée sa demande, l'admin la valide (update).
      allow create: if isSignedIn() && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /affiliate_transactions/{id} {
      allow read: if isSignedIn() && (resource.data.affiliateId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // --- SUPPORT & MESSAGERIE ---
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn();
      }
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
      }
    }

    // --- RÉGLAGES SYSTÈME & CONTENU PUBLIC ---
    match /settings/{id} {
      allow read: if true; // Lecture publique pour le nom du site, logos, etc.
      allow write: if isAdmin();
    }

    match /faqs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carousel_slides/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- LOGS & AUDIT (VERROUILLÉS - SERVER ONLY) ---
    match /admin_audit_logs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /security_logs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- COURS & PÉDAGOGIE ---
    match /courses/{courseId} {
      allow read: if true; // Catalogue public.
      allow write: if isAdmin() || (
        isSignedIn() && 
        resource.data.instructorId == request.auth.uid && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restrictions.canSellCourse == true
      );
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
    }

    match /enrollments/{id} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
      allow write: if false; // Les inscriptions sont traitées par le processeur financier serveur.
    }

    match /course_progress/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /user_wishlist/{id} {
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /course_reviews/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
    }

    match /questions/{id} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
    }

    // --- AUTRES ---
    match /countries/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /course_coupons/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);
    }

    match /investor_leads/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
    }

    match /push_campaigns/{id} {
      allow read, write: if isAdmin();
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLES PAR DÉFAUT : FERMÉ ---
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- UTILISATEURS ---
    match /users/{userId} {
      allow read: if isSignedIn(); // Permet l'annuaire et la recherche
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /notifications/{notifId} { allow read, write: if isOwner(userId); }
      match /chatHistory/{msgId} { allow read, write: if isOwner(userId); }
      match /activity/{actId} { allow read: if isOwner(userId) || isAdmin(); }
    }

    // --- FINANCES & TRANSACTIONS ---
    match /payments/{paymentId} {
      // Un utilisateur ne peut voir que ses propres paiements
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Seul le serveur via Admin SDK peut écrire
    }

    match /payout_requests/{payoutId} {
      allow read: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); // Création possible, mais auditée par le serveur
      allow update: if isAdmin();
    }

    // --- RÉGLAGES SYSTÈME (PROTECTION CRITIQUE) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- LOGS & AUDIT ---
    match /admin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Strictement réservé au serveur
    }

    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isSignedIn(); // Permet au système de logger des alertes
    }

    // --- COURS & CONTENU ---
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /sections/{sectionId} {
        allow read: if true;
        match /lectures/{lectureId} { allow read: if true; }
        match /quizzes/{quizId} { allow read: if true; }
      }
    }
  }
}
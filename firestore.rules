rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLE PAR DÉFAUT : TOUT EST FERMÉ ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- UTILISATEURS ---
    match /users/{userId} {
      // Un utilisateur peut lire son profil. Les admins peuvent tout lire.
      allow read: if isOwner(userId) || isAdmin();
      // Création autorisée uniquement pour soi-même à l'inscription
      allow create: if isOwner(userId);
      // Mise à jour restreinte (le rôle ne peut pas être changé par l'utilisateur via le client)
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin();
      
      match /notifications/{id} { allow read, write: if isOwner(userId); }
      match /chatHistory/{id} { allow read, write: if isOwner(userId); }
      match /activity/{id} { allow read: if isOwner(userId) || isAdmin(); }
      match /cart/{id} { allow read, write: if isOwner(userId); }
    }

    // --- ENROLLMENTS (INSCRIPTIONS) ---
    match /enrollments/{enrollmentId} {
      // ✅ SÉCURITÉ FINTECH : Lecture autorisée si l'ID commence par l'UID ou si le champ studentId match.
      // Cela permet le 'get' (vérification d'accès) et le 'list' (mes formations).
      allow read: if isSignedIn() && (
        enrollmentId.startsWith(request.auth.uid) || 
        (resource != null && resource.data.studentId == request.auth.uid) ||
        isAdmin()
      );
      // ✅ PROTECTION : Seul le Backend (Admin SDK) peut inscrire un utilisateur.
      allow write: if isAdmin();
    }

    // --- PAYMENTS (TRANSACTIONS) ---
    match /payments/{paymentId} {
      // Un utilisateur ne voit que ses propres reçus.
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      // ✅ PROTECTION : Aucune modification financière depuis le client.
      allow write: if false;
    }

    // --- COURS & CONTENU ---
    match /courses/{courseId} {
      allow read: if true; 
      allow write: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /course_progress/{id} {
      allow read: if isOwner(id.split('_')[0]) || isAdmin();
      allow write: if isOwner(id.split('_')[0]);
    }

    // --- SUPPORT & MESSAGERIE ---
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    match /admin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}